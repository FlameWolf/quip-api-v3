{
	"compilerOptions": {
		"target": "ESNext",
		"module": "NodeNext",
		"verbatimModuleSyntax": true,
		"allowImportingTsExtensions": true,
		"rewriteRelativeImportExtensions": true,
		"strict": true,
		"skipLibCheck": true,
		"types": ["node"],
		"jsx": "react-jsx",
		"jsxImportSource": "hono/jsx",
		"outDir": "./dist",
		"typeRoots": ["./types", "./node_modules/@types"]
	},
	"exclude": ["node_modules"]
}